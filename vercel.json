{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["arn1"],
  "functions": {
    "app/api/admin/recompress-images/route.ts": { "maxDuration": 300 },
    "app/api/admin/sync/card/[cardId]/route.ts": { "maxDuration": 60 },
    "app/api/admin/sync/prices/route.ts": { "maxDuration": 300 },
    "app/api/bulk-import-images/route.ts": { "maxDuration": 300 },
    "app/api/import-card-data/route.ts": { "maxDuration": 120 },
    "app/api/prices/discover/route.ts": { "maxDuration": 60 },
    "app/api/prices/sync/route.ts": { "maxDuration": 120 }
  },
  "crons": [
    { "path": "/api/cron/update-prices", "schedule": "0 1 * * *" },
    { "path": "/api/prices/cron/raw", "schedule": "30 1 * * *" },
    { "path": "/api/prices/cron/graded", "schedule": "0 2 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-DNS-Prefetch-Control", "value": "on" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.+)\\.(ico|png|jpg|jpeg|svg|webp|gif|woff|woff2|ttf|eot)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.lumidex.app" }],
      "destination": "https://lumidex.app/$1",
      "permanent": true
    }
  ]
}
